# Basis-URL til Keycloak-realmen (OIDC-discovery hentes herfra).
# Lokal verdi forutsetter at docker-compose-stacken kjører.
KEYCLOAK_ISSUER_URL=http://localhost:8601/realms/matrikkel

# OAuth2-klient registrert i Keycloak-realmen.
KEYCLOAK_CLIENT_ID=matrikkel-token-exchange

# Kommaseparert liste over gyldige audience-verdier i JWT-tokenet.
ACCEPTED_AUDIENCES=matrikkel-token-exchange

# URL til GeoServer som proxyen videresender til.
# Lokal verdi forutsetter at docker-compose-stacken kjører.
GEOSERVER_URL=http://localhost:8681

# Port proxyen lytter på.
PORT=8602