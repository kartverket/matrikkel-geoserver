<wfs>
    <id>wfs</id>
    <enabled>true</enabled>
    <name>Matrikkelen WFS</name>
    <title>Matrikkelen WFS</title>
    <maintainer>Statens Kartverk</maintainer>
    <abstrct>Dette er WFS tjenestene til Matrikkelsystemet. Den stoetter uthenting av alle geometri-objektene fra&#xd;
        Matrikkelen.
    </abstrct>
    <accessConstraints>Bruker med rettigheter til innsyn i Matrikkelen</accessConstraints>
    <fees>NONE</fees>
    <versions>
        <org.geotools.util.Version>
            <version>1.0.0</version>
        </org.geotools.util.Version>
        <org.geotools.util.Version>
            <version>1.1.0</version>
        </org.geotools.util.Version>
        <org.geotools.util.Version>
            <version>2.0.0</version>
        </org.geotools.util.Version>
    </versions>
    <keywords>
        <string>WFS</string>
        <string>WMS</string>
        <string>GEOSERVER</string>
        <string>Matrikkelen</string>
    </keywords>
    <metadataLink/>
    <citeCompliant>false</citeCompliant>
    <onlineResource>https://www.matrikkel.no:443/innsyn_v03/docs</onlineResource>
    <schemaBaseURL>http://schemas.opengis.net</schemaBaseURL>
    <verbose>false</verbose>
    <metadata>
        <entry key="SHAPE-ZIP_DEFAULT_PRJ_IS_ESRI">false</entry>
    </metadata>
    <gml>
        <entry>
            <version>V_10</version>
            <gml>
                <srsNameStyle>XML</srsNameStyle>
                <overrideGMLAttributes>true</overrideGMLAttributes>
            </gml>
        </entry>
        <entry>
            <version>V_20</version>
            <gml>
                <srsNameStyle>URN2</srsNameStyle>
                <overrideGMLAttributes>false</overrideGMLAttributes>
            </gml>
        </entry>
        <entry>
            <version>V_11</version>
            <gml>
                <srsNameStyle>URN</srsNameStyle>
                <overrideGMLAttributes>false</overrideGMLAttributes>
            </gml>
        </entry>
    </gml>
    <serviceLevel>BASIC</serviceLevel>
    <maxFeatures>10000</maxFeatures>
    <featureBounding>true</featureBounding>
    <canonicalSchemaLocation>true</canonicalSchemaLocation>
    <encodeFeatureMember>false</encodeFeatureMember>
    <hitsIgnoreMaxFeatures>false</hitsIgnoreMaxFeatures>
