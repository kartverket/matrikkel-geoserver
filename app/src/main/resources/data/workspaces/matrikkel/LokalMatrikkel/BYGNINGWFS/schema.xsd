                    <xs:element type="xs:boolean" minOccurs="0" name="SEFRAKMINNE" nillable="true"/>
                    <xs:element type="gml:PointPropertyType" minOccurs="0" name="REPRESENTASJONSPUNKT" nillable="true"/>
